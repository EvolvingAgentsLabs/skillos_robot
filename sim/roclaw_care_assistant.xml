<!--
  RoClaw Care Assistant Scene

  4x4m arena with two "people" (yellow and orange cubes) near the robot's
  starting position and two "doors" (tall blue and green cubes) on the
  north side of the arena. The robot should approach a person, ask which
  door they want, then navigate to it.

  Layout (top-down, Y=north):
    +----------------------------+
    |                            |
    |  [blue_door]  [green_door] |   y = 1.5
    |  (-0.8,1.5)   (0.8,1.5)   |
    |                            |
    |         [obstacle]         |   y = 0.5
    |         (0.3,0.5)          |
    |                            |
    |                            |
    |  [person_1]    [person_2]  |   y = -0.5
    |  (-0.6,-0.5)   (0.6,-0.5) |
    |                            |
    |         [ROBOT]            |   y = -1.0
    |         (0,-1.0)           |
    +----------------------------+

  Tests: conversation, goal selection, multi-target navigation.
-->
<mujoco model="RoClaw_CareAssistant">
  <compiler angle="radian"/>

  <option timestep="0.002" gravity="0 0 -9.81" integrator="implicit"/>

  <default>
    <geom condim="3" friction="1.0 0.005 0.0001"/>
    <joint damping="0.01"/>
  </default>

  <asset>
    <texture name="grid" type="2d" builtin="checker"
             rgb1="0.9 0.9 0.9" rgb2="0.7 0.7 0.7"
             width="512" height="512"/>
    <material name="grid_mat" texture="grid" texrepeat="8 8" texuniform="true"/>
    <material name="chassis_mat" rgba="0.2 0.2 0.8 1"/>
    <material name="wheel_mat" rgba="0.15 0.15 0.15 1"/>
    <material name="caster_mat" rgba="0.6 0.6 0.6 1"/>
    <!-- People: warm colors -->
    <material name="person1_mat" rgba="1.0 0.85 0.0 1"/>
    <material name="person2_mat" rgba="1.0 0.5 0.0 1"/>
    <!-- Doors: cool colors -->
    <material name="blue_door_mat" rgba="0.2 0.4 0.9 1"/>
    <material name="green_door_mat" rgba="0.2 0.8 0.3 1"/>
    <!-- Obstacle -->
    <material name="obstacle_mat" rgba="0.5 0.5 0.5 1"/>
  </asset>

  <visual>
    <headlight ambient="0.3 0.3 0.3" diffuse="0.5 0.5 0.5"/>
  </visual>

  <worldbody>
    <light name="overhead" pos="0 0 1.5" dir="0 0 -1"
           diffuse="0.8 0.8 0.8" specular="0.2 0.2 0.2" directional="true"/>

    <!-- Ground plane -->
    <geom name="floor" type="plane" size="2 2 0.01" material="grid_mat"/>

    <!-- Arena walls -->
    <geom name="wall_north" type="box" pos="0 2 0.05" size="2 0.02 0.05" rgba="0.5 0.5 0.5 0.3"/>
    <geom name="wall_south" type="box" pos="0 -2 0.05" size="2 0.02 0.05" rgba="0.5 0.5 0.5 0.3"/>
    <geom name="wall_east" type="box" pos="2 0 0.05" size="0.02 2 0.05" rgba="0.5 0.5 0.5 0.3"/>
    <geom name="wall_west" type="box" pos="-2 0 0.05" size="0.02 2 0.05" rgba="0.5 0.5 0.5 0.3"/>

    <!-- Person 1: yellow cube (southwest) -->
    <body name="person_1" pos="-0.6 -0.5 0.1">
      <geom type="box" size="0.1 0.1 0.15" material="person1_mat"/>
    </body>

    <!-- Person 2: orange cube (southeast) -->
    <body name="person_2" pos="0.6 -0.5 0.1">
      <geom type="box" size="0.1 0.1 0.15" material="person2_mat"/>
    </body>

    <!-- Blue door: tall blue cube (northwest) -->
    <body name="blue_door" pos="-0.8 1.5 0.15">
      <geom type="box" size="0.12 0.12 0.25" material="blue_door_mat"/>
    </body>

    <!-- Green door: tall green cube (northeast) -->
    <body name="green_door" pos="0.8 1.5 0.15">
      <geom type="box" size="0.12 0.12 0.25" material="green_door_mat"/>
    </body>

    <!-- Small obstacle in the middle -->
    <body name="obstacle" pos="0.3 0.5 0.05">
      <geom type="box" size="0.08 0.08 0.05" material="obstacle_mat"/>
    </body>

    <!-- External overhead camera -->
    <camera name="external_cam" pos="0 0 1.2" xyaxes="1 0 0 0 1 0"
            fovy="90" resolution="640 480"/>

    <!-- ============== RoClaw Robot ============== -->
    <body name="chassis" pos="0 -1.0 0.06">
      <freejoint name="root"/>

      <geom name="chassis_geom" type="box"
            size="0.075 0.05 0.025"
            mass="0.3"
            material="chassis_mat"/>

      <camera name="eyes" pos="0.075 0 0.02" xyaxes="0 -1 0 0 0 1"
              fovy="65" resolution="320 240"/>

      <!-- Left wheel -->
      <body name="left_wheel" pos="0 0.05 -0.025">
        <joint name="left_wheel_joint" type="hinge" axis="0 1 0" damping="0.005"/>
        <geom name="left_wheel_geom" type="cylinder"
              size="0.03 0.01"
              euler="1.5708 0 0"
              mass="0.05"
              material="wheel_mat"
              friction="1.5 0.005 0.0001"/>
      </body>

      <!-- Right wheel -->
      <body name="right_wheel" pos="0 -0.05 -0.025">
        <joint name="right_wheel_joint" type="hinge" axis="0 1 0" damping="0.005"/>
        <geom name="right_wheel_geom" type="cylinder"
              size="0.03 0.01"
              euler="1.5708 0 0"
              mass="0.05"
              material="wheel_mat"
              friction="1.5 0.005 0.0001"/>
      </body>

      <!-- Rear caster ball -->
      <body name="caster" pos="-0.06 0 -0.025">
        <joint name="caster_x" type="hinge" axis="1 0 0" damping="0.001"/>
        <joint name="caster_y" type="hinge" axis="0 1 0" damping="0.001"/>
        <geom name="caster_geom" type="sphere"
              size="0.015"
              mass="0.02"
              material="caster_mat"
              friction="0.05 0.001 0.0001"/>
      </body>
    </body>
  </worldbody>

  <actuator>
    <velocity name="left_wheel" joint="left_wheel_joint"
              ctrlrange="-1.571 1.571" kv="1.0"/>
    <velocity name="right_wheel" joint="right_wheel_joint"
              ctrlrange="-1.571 1.571" kv="1.0"/>
  </actuator>
</mujoco>
