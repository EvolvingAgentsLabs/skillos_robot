# OpenClaw Gateway
OPENCLAW_GATEWAY_URL=ws://localhost:8080

# ESP32 Hardware
ESP32_S3_HOST=192.168.1.100
ESP32_S3_PORT=4210
ESP32_CAM_HOST=192.168.1.101
ESP32_CAM_PORT=80
# Camera stream path (default: /stream for ESP32-CAM)
# For Android IP Webcam app: /video
# For DroidCam: /mjpegfeed
# See docs/05-Camera-Setup.md for full guide
ESP32_CAM_PATH=/stream

# Vision Loop
# Number of frames in the rolling video buffer (default: 4)
# The VLM receives this many consecutive frames as a "video clip"
# to perceive velocity, depth, and 3D spatial context.
FRAME_HISTORY_SIZE=4

# Inference (OpenRouter or local)
OPENROUTER_API_KEY=sk-or-v1-...
QWEN_MODEL=qwen/qwen-2.5-vl-72b-instruct
# For local inference, set this instead:
# LOCAL_INFERENCE_URL=http://localhost:8000/v1/chat/completions

# --- Ollama + Qwen3-VL (local, recommended) ---
# Best setup: runs entirely on your machine, no API costs, 100% private.
# Qwen3-VL supports video understanding, 3D grounding, and 256K context.
#
# Setup:
# 1. Install Ollama: curl -fsSL https://ollama.com/install.sh | sh
# 2. Pull model: ollama pull qwen3-vl:8b-instruct
# 3. Uncomment the two lines below:
# LOCAL_INFERENCE_URL=http://localhost:11434/v1
# QWEN_MODEL=qwen3-vl:8b-instruct
#
# For faster inference with smaller model:
# QWEN_MODEL=qwen3-vl:2b

# IP Webcam sensor source (for compass heading from Android phone)
# Only IP Webcam exposes sensors via HTTP — DroidCam does not.
# IP_WEBCAM_HOST=192.168.1.50
# IP_WEBCAM_PORT=8080

# --- Gemini Robotics-ER (alternative VLM backend) ---
# Uses Google's Gemini API with native tool calling and spatial grounding.
# Activates with --gemini CLI flag. Falls back to Qwen-VL when not set.
# GOOGLE_API_KEY=AIza...
# GEMINI_MODEL=gemini-robotics-er-1.5-preview    # Model identifier (default: gemini-robotics-er-1.5-preview)
# GEMINI_THINKING_BUDGET=0                      # 0 = fast motor loop, >0 = deep analysis tokens
# DREAM_PROVIDER=gemini                         # Force Gemini for dream consolidation ("gemini" or unset for OpenRouter)

# Dreaming Engine v2
# DREAM_MODEL=qwen/qwen-2.5-vl-72b-instruct   # Can use a cheaper model for offline consolidation
# DREAM_MAX_TOKENS=2048                         # Higher than motor control (64)
# DREAM_TEMPERATURE=0.3                         # More creative than deterministic bytecodes (0.1)
# DREAM_BATCH_SIZE=10                           # Max trace sequences per LLM call
# DREAM_WINDOW_DAYS=7                           # Only process traces from last N days
# DREAM_RETENTION_DAYS=7                        # Delete trace files older than N days

# Kaggle API credentials (only needed to download vision test fixtures)
# Get token at: https://www.kaggle.com/settings → API → Create New Token
# KAGGLE_USERNAME=your-username
# KAGGLE_KEY=your-api-key
